# LLM provider: anthropic | openai | deepseek | openrouter | ollama | gemini | antigravity
BUILDER_LLM=deepseek
BUILDER_MODEL=

# API keys (set one matching BUILDER_LLM)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=

# Google Gemini free tier (AI Studio) — direct API, no Antigravity needed
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Antigravity Manager (local OpenAI-compatible proxy — NOT Google AI Studio key)
ANTIGRAVITY_API_KEY=sk-antigravity
ANTIGRAVITY_BASE_URL=http://127.0.0.1:8045/v1

# Cursor (Composer / Cloud Agents)
CURSOR_API_KEY=

# Ollama local (BUILDER_LLM=ollama)
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1

# Web chat UI
# WEB_PASSWORD=optional_site_password
# PORT=8080

# Matrix (for generated scripts)
MATRIX_USER=
MATRIX_PASS=
