# ═══════════════════════════════════════════════════════════════
# Hassan AI Agent — VPS Production .env
# Copy to server:  cp deploy/vps.env /root/hassanaiagent/.env
# Then edit keys:  nano /root/hassanaiagent/.env
# Restart:         sudo systemctl restart hassan-ai
# ═══════════════════════════════════════════════════════════════
# RULES (zaroori):
#   • Sirf EK copy — duplicate mat karo
#   • Har key EK line mein — line break mat lagao
#   • Supabase JWT poori paste karo (~200+ chars, ends with letters/numbers, NOT >)
#   • Dashboard: https://supabase.com/dashboard/project/nbfzdezmvggmmvhkkvbt/settings/api
# ═══════════════════════════════════════════════════════════════

# ─── Supabase (chat memory + auth — cloud, NOT local SQLite) ───
SUPABASE_URL=https://nbfzdezmvggmmvhkkvbt.supabase.co
SUPABASE_PROJECT_ID=nbfzdezmvggmmvhkkvbt

# Settings → API → anon public → Copy (poori key ek line)
SUPABASE_ANON_KEY=PASTE_FULL_ANON_JWT_HERE

# Settings → API → service_role secret → Copy (poori key ek line)
SUPABASE_SERVICE_ROLE_KEY=PASTE_FULL_SERVICE_ROLE_JWT_HERE

# ─── Admin panel (https://hassanai.xyz/admin) ─────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=HassanAdmin2026!

# ─── LLM default (Gemini Free) ────────────────────────────────
BUILDER_LLM=gemini
BUILDER_MODEL=gemini-3.1-flash-lite
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=PASTE_YOUR_GEMINI_KEY_HERE

# ─── Optional providers (blank = off) ───────────────────────────
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
# OPENROUTER_API_KEY=
# CURSOR_API_KEY=

# ─── CORS (production domain) ───────────────────────────────────
CORS_ORIGINS=https://hassanai.xyz,https://www.hassanai.xyz,http://localhost:8080

# ─── Chat context (messages sent to LLM per conversation) ───────
CHAT_CONTEXT_MESSAGES=40
